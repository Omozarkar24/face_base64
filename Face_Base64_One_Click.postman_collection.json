{
  "info": {
    "_postman_id": "d9ff9f53-a6b2-4c8d-88ec-14370e1d0df1",
    "name": "Face Base64 API (One-Click)",
    "description": "One-click Postman import for Upsert and Fetch verification flows.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "userId",
      "value": "user_202"
    },
    {
      "key": "matchingBase64",
      "value": "c2VjcmV0NDU2"
    },
    {
      "key": "wrongBase64",
      "value": "wrong_base64"
    }
  ],
  "item": [
    {
      "name": "1) Upsert User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_id\": \"{{userId}}\",\n  \"name\": \"Bob\",\n  \"langlong\": \"28.6139,77.2090\",\n  \"base64_value\": \"{{matchingBase64}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/users/upsert",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users",
            "upsert"
          ]
        },
        "description": "Create or update user in backend."
      }
    },
    {
      "name": "2) Fetch - Matched (code 500)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_id\": \"{{userId}}\",\n  \"base64_value\": \"{{matchingBase64}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/fetch-data",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "fetch-data"
          ]
        },
        "description": "Expected response contains code 500."
      }
    },
    {
      "name": "3) Fetch - Not Matched (code 502)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_id\": \"{{userId}}\",\n  \"base64_value\": \"{{wrongBase64}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/fetch-data",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "fetch-data"
          ]
        },
        "description": "Expected response contains code 502."
      }
    },
    {
      "name": "4) Fetch - User/Image Not Found (code 501)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_id\": \"user_999\",\n  \"base64_value\": \"{{matchingBase64}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/fetch-data",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "fetch-data"
          ]
        },
        "description": "Expected response contains code 501."
      }
    },
    {
      "name": "5) Get User",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users/{{userId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users",
            "{{userId}}"
          ]
        },
        "description": "Check current backend record for the user."
      }
    }
  ]
}
