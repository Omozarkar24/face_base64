  ],
  "item": [
    {
      "name": "1) Upsert User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_id\": \"{{userId}}\",\n  \"name\": \"Bob\",\n  \"langlong\": \"28.6139,77.2090\",\n  \"base64_value\": \"c2VjcmV0NDU2\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/users/upsert",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users",
            "upsert"
          ]
        },
        "description": "Create or update a user record in backend DB."
      }
    },
    {
      "name": "2) Verify Base64",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_id\": \"{{userId}}\",\n  \"base64_value\": \"c2VjcmV0NDU2\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/fetch-data",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "fetch-data"
          ]
        },
        "description": "Verify submitted base64 against backend value."
      }
    },
    {
      "name": "3) Get User",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users/{{userId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users",
            "{{userId}}"
          ]
        },
        "description": "Fetch current backend record for a user."
      }
    }
  ]
}
